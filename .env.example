# Copie para .env na raiz do monveo (opcional) ou exporte no shell.
# O arquivo .env real não deve ser commitado.

# Caminho no host para o JSON da service account (usado pelo docker-compose)
# MONVEO_GOOGLE_APPLICATION_CREDENTIALS=./backend/google_auth.json

# Dentro do container o backend usa sempre:
# GOOGLE_APPLICATION_CREDENTIALS=/secrets/google_auth.json

# Bucket GCS para imagens (já tem padrão no docker-compose)
# GCS_BUCKET=monveo-seo-images
